{
  "name": "@veritas-kanban/cli",
  "version": "3.3.3",
  "description": "CLI for Veritas Kanban task management",
  "type": "module",
  "bin": {
    "vk": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.config.mjs",
    "build:standalone": "node build-standalone.mjs",
    "build:windows": "node build-standalone.mjs --target windows",
    "build:all": "node build-standalone.mjs --target all",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@veritas-kanban/shared": "workspace:*",
    "commander": "^14.0.3",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  },
  "license": "MIT",
  "author": "Brad Groux <brad@digitalmeld.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/invidtiv/veritas-kanban.git"
  }
}
