{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "vitest"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "electron.vite.config.ts"],
  "exclude": ["dist", "out", "node_modules"]
}
